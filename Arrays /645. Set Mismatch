class Solution {
    public int[] findErrorNums(int[] nums) {
        int[] res = new int[2];
        int[] freq = new int[nums.length];
        for(int i=0;i<nums.length;i++){
            freq[nums[i]-1]++;
            if(freq[nums[i]-1]==2)res[0] = nums[i];
        }
        for(int i=0;i<freq.length;i++){
            if(freq[i]==0) res[1] = i+1;
        }
        return res;
    }
}
