class Solution {
    public int[] finalPrices(int[] prices) {
        int[] res = new int[prices.length];
        Stack<Integer> st = new Stack<>();
        int n = prices.length;
        res[n-1] = prices[n-1];
        st.push(prices[n-1]);
        for(int i=n-2;i>=0;i--){
            while(!st.isEmpty() && st.peek()>prices[i]){
                st.pop();
            }
            if(st.empty()){
                res[i] = prices[i];
            }
            else{
                res[i] = prices[i]-st.peek();
            }
            st.push(prices[i]);
        }
        return res;
    }
}
